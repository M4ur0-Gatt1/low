{
  "name": "low2-hybrid",
  "version": "2.0.0-alpha",
  "description": "LOW 2.0 - Arquitectura híbrida con motores nativos de alto rendimiento",
  "main": "src/main/index.js",
  "scripts": {
    "build:native": "cmake -B build/native -S native && cmake --build build/native --config Release",
    "build:app": "tsc && npm run build:renderer",
    "build:renderer": "vite build",
    "build": "npm run build:native && npm run build:app",
    "dev": "concurrently \"npm run dev:native\" \"npm run dev:app\"",
    "dev:native": "cmake --build build/native --config Debug --target watch",
    "dev:app": "vite",
    "test": "jest",
    "test:native": "ctest --test-dir build/native",
    "package": "electron-builder",
    "installer": "node scripts/create-installer.js"
  },
  "keywords": [
    "3d",
    "drawing",
    "cad",
    "illustration",
    "design",
    "native",
    "performance"
  ],
  "author": "LOW Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0",
    "codemirror": "^5.65.16",
    "axios": "^1.6.5",
    "simple-git": "^3.22.0",
    "ssh2": "^1.15.0",
    "electron-store": "^8.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "node-addon-api": "^7.1.0",
    "node-gyp": "^10.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "nativeAddon": {
    "name": "low-native-bridge",
    "sources": [
      "native/bridge/*.cpp",
      "native/core/*.cpp"
    ],
    "include_dirs": [
      "native/include",
      "native/core/include"
    ],
    "libraries": [
      "opengl32",
      "glu32"
    ]
  },
  "build": {
    "appId": "com.low.app",
    "productName": "LOW 2.0",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "modules/**/*",
      "native/build/**/*.node",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "LOW-2.0-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LOW 2.0"
    }
  }
}
